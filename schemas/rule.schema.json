{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DaC Detection Rule Schema v1 — ES|QL Only",
  "type": "object",
  "required": [
    "schema_version",
    "rule_id",
    "metadata",
    "name",
    "description",
    "enabled",
    "type",
    "language",
    "severity",
    "risk_score",
    "tags",
    "index",
    "query",
    "interval",
    "from",
    "to"
  ],
  "properties": {

    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Must always be 1"
    },

    "rule_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
      "description": "UUID v4 — generated once, never changed"
    },

    "metadata": {
      "type": "object",
      "required": [
        "creation_date",
        "updated_date",
        "maturity",
        "author"
      ],
      "properties": {
        "creation_date": {
          "type": "string",
          "pattern": "^[0-9]{4}/[0-9]{2}/[0-9]{2}$",
          "description": "YYYY/MM/DD"
        },
        "updated_date": {
          "type": "string",
          "pattern": "^[0-9]{4}/[0-9]{2}/[0-9]{2}$",
          "description": "YYYY/MM/DD"
        },
        "maturity": {
          "type": "string",
          "enum": ["production", "development", "deprecated"]
        },
        "author": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },

    "name": {
      "type": "string",
      "minLength": 5,
      "description": "Human readable rule name"
    },

    "description": {
      "type": "string",
      "minLength": 10,
      "description": "What this rule detects and why"
    },

    "enabled": {
      "type": "boolean",
      "description": "true = prod/enabled | false = prod/disabled"
    },

    "type": {
      "type": "string",
      "const": "esql",
      "description": "All new rules must be esql"
    },

    "language": {
      "type": "string",
      "const": "esql",
      "description": "All new rules must be esql"
    },

    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },

    "risk_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "low=21 medium=47 high=73 critical=99"
    },

    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"},
      "description": "At least one tag required"
    },

    "index": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"},
      "description": "Index patterns the rule searches"
    },

    "query": {
      "type": "string",
      "minLength": 10,
      "description": "ES|QL query"
    },

    "interval": {
      "type": "string",
      "pattern": "^[0-9]+(m|h)$",
      "description": "e.g. 5m, 1h, 24h"
    },

    "from": {
      "type": "string",
      "pattern": "^now-[0-9]+(s|m|h)$",
      "description": "Look-back window e.g. now-65m"
    },

    "to": {
      "type": "string",
      "const": "now",
      "description": "Always now"
    },

    "timestamp_override": {
      "type": "string",
      "description": "Optional — use event.ingested for cloud sources"
    },

    "timestamp_override_fallback_disabled": {
      "type": "boolean",
      "description": "Optional — false when timestamp_override is set"
    },

    "threat": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["framework", "tactic"],
        "properties": {
          "framework": {
            "type": "string",
            "const": "MITRE ATT&CK"
          },
          "tactic": {
            "type": "object",
            "required": ["id", "name", "reference"],
            "properties": {
              "id": {"type": "string"},
              "name": {"type": "string"},
              "reference": {
                "type": "string",
                "description": "Must end with trailing slash"
              }
            }
          },
          "technique": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name", "reference"],
              "properties": {
                "id": {"type": "string"},
                "name": {"type": "string"},
                "reference": {"type": "string"},
                "subtechnique": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "name", "reference"],
                    "properties": {
                      "id": {"type": "string"},
                      "name": {"type": "string"},
                      "reference": {"type": "string"}
                    }
                  }
                }
              }
            }
          }
        }
      }
    },

    "investigation_fields": {
      "type": "object",
      "properties": {
        "field_names": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },

    "note": {
      "type": "string",
      "description": "Triage and investigation guide"
    },

    "false_positives": {
      "type": "array",
      "items": {"type": "string"}
    },

    "references": {
      "type": "array",
      "items": {"type": "string"}
    },

    "max_signals": {
      "type": "integer",
      "const": 100
    },

    "exceptions_list": {
      "type": "array",
      "maxItems": 0,
      "description": "Always empty in Phase 1"
    },

    "actions": {
      "type": "array",
      "maxItems": 0,
      "description": "Always empty — Jira actions managed in Kibana directly"
    }

  },
  "additionalProperties": false
}
